# Copy this to config.env and customize before deploy.
#
# Hugging Face token: set HF_TOKEN in your shell (`export HF_TOKEN=...`) for
# operator-local deploys, or rely on the transcribe-modal-bridge server to
# inject it for production. The token is consumed only during image build to
# bake pyannote weights into the image; the runtime function attaches no
# Modal Secret, so end users never see an HF entry in their workspace.

# Modal App identity
MODAL_APP_NAME=transcribe-modal-gpu

# GPU resource sizing
MODAL_GPU_TYPE=L4
MODAL_CPU=4
MODAL_MEMORY=8192
MODAL_GPU_TIMEOUT=1800
MODAL_SCALEDOWN_WINDOW=900

# Default model used at image-build time for model preloading.
# Runtime model is decided per-request by the caller.
DEFAULT_MODEL_SIZE=large-v3
# Build-time model downloads can hit transient connection resets. These retry
# settings cover Whisper and Hugging Face snapshot prefetches.
MODEL_DOWNLOAD_RETRIES=4
MODEL_DOWNLOAD_RETRY_DELAY_SECONDS=20

# Fallback ASR backend when an older caller does not pass asr_backend.
# Product routing should happen in the CPU function per request, based on the
# user's plan, by passing asr_backend=whisper or asr_backend=qwen3_asr.
ASR_BACKEND=whisper

# Qwen3-ASR backend. ForcedAligner is mandatory for Qwen
# transcription so returned segments preserve start/end timestamps for SRT.
# The aligner supports longer inputs, but 60s keeps Qwen ASR context focused for
# better proper-noun and acronym accuracy. Increase only after comparison tests.
QWEN_ASR_MODEL_ID=Qwen/Qwen3-ASR-1.7B
# Optional comma-separated request override allowlist. Blank means only
# QWEN_ASR_MODEL_ID is allowed.
QWEN_ALLOWED_ASR_MODEL_IDS=
QWEN_FORCED_ALIGNER_MODEL_ID=Qwen/Qwen3-ForcedAligner-0.6B
QWEN_ASR_RUNTIME=vllm
QWEN_TRANSFORMERS_BATCH_SIZE=1
QWEN_VLLM_DTYPE=bfloat16
QWEN_ALIGNER_DTYPE=
QWEN_VLLM_BATCH_SIZE=4
QWEN_VLLM_GPU_MEMORY_UTILIZATION=0.70
QWEN_VLLM_MAX_MODEL_LEN=8192
QWEN_ALIGNER_MAX_SEGMENT_SECONDS=60
QWEN_MAX_NEW_TOKENS=1024
# Optional Qwen3-ASR context/hotword-style hints. Prefer passing qwen_context
# per request when product metadata is available.
QWEN_ASR_CONTEXT=
QWEN_SUBTITLE_MAX_SECONDS=2.4
QWEN_SUBTITLE_MAX_CHARS=28
QWEN_SUBTITLE_GAP_SECONDS=0.50

# Pyannote diarization runtime tuning. Community-1 ships with 32/32 defaults;
# the service defaults to 256/256 to better use L4 GPU memory, and these vars
# let operators tune upward/downward without code changes.
PYANNOTE_SEGMENTATION_BATCH_SIZE=256
PYANNOTE_EMBEDDING_BATCH_SIZE=256
PYANNOTE_USE_MEMORY_INPUT=true
PYANNOTE_PROGRESS_HOOK=true

# Copy this to config.env and customize before deploy.
#
# Hugging Face token: set HF_TOKEN in your shell (`export HF_TOKEN=...`) for
# operator-local deploys, or rely on the transcribe-modal-bridge server to
# inject it for production. The token is consumed only during image build to
# bake pyannote weights into the image; the runtime function attaches no
# Modal Secret, so end users never see an HF entry in their workspace.

# Modal App identity
MODAL_APP_NAME=transcribe-modal-gpu

# GPU resource sizing
MODAL_GPU_TYPE=T4
MODAL_CPU=4
MODAL_MEMORY=8192
MODAL_GPU_TIMEOUT=1800

# Default model used at image-build time for model preloading.
# Runtime model is decided per-request by the caller.
DEFAULT_MODEL_SIZE=large-v3

# ASR backend. Default stays Whisper for backwards compatibility.
# Set ASR_BACKEND=qwen3_asr to route chunk transcription through Qwen3-ASR.
ASR_BACKEND=whisper

# Qwen3-ASR transformers backend. ForcedAligner is mandatory for Qwen
# transcription so returned segments preserve start/end timestamps for SRT.
# The aligner supports up to a few minutes per input; 180s is conservative for
# T4 test deployments.
QWEN_ASR_MODEL_ID=Qwen/Qwen3-ASR-0.6B
QWEN_FORCED_ALIGNER_MODEL_ID=Qwen/Qwen3-ForcedAligner-0.6B
QWEN_ALIGNER_MAX_SEGMENT_SECONDS=180
QWEN_MAX_NEW_TOKENS=1024
QWEN_SUBTITLE_MAX_SECONDS=1.6
QWEN_SUBTITLE_MAX_CHARS=12
QWEN_SUBTITLE_GAP_SECONDS=0.35

# Pyannote diarization runtime tuning. Community-1 ships with 32/32 defaults;
# the service defaults to 128/128 to better use T4 GPU memory, and these vars
# let operators tune upward/downward without code changes.
PYANNOTE_SEGMENTATION_BATCH_SIZE=128
PYANNOTE_EMBEDDING_BATCH_SIZE=128
PYANNOTE_USE_MEMORY_INPUT=true
PYANNOTE_PROGRESS_HOOK=true
